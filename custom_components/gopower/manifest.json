{
  "domain": "gopower",
  "name": "GoPower Solar",
  "codeowners": ["@petehurth"],
  "config_flow": true,
  "dependencies": ["bluetooth_adapters"],
  "documentation": "https://github.com/phurth/ha-gopower",
  "bluetooth": [
    {
      "local_name": "GP-PWM*"
    },
    {
      "local_name": "GoPower*"
    }
  ],
  "iot_class": "local_polling",
  "requirements": ["bleak>=0.21.0", "bleak-retry-connector>=3.1.0"],
  "version": "0.1.0"
}
